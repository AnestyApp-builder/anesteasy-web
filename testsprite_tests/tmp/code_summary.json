{
  "tech_stack": [
    "TypeScript",
    "Next.js 15 (App Router)",
    "React 19",
    "Tailwind CSS",
    "Supabase (PostgreSQL, Auth, Storage, Edge Functions, RLS)",
    "Stripe",
    "SMTP/Resend email",
    "Tesseract.js OCR",
    "Recharts"
  ],
  "features": [
    {
      "name": "Auth and User Management",
      "description": "Registro, login, confirmação de email, recuperação de senha e gestão de perfis para anestesiologistas e secretárias, com controle de sessão e redirecionamento de acordo com o tipo de usuário.",
      "files": [
        "app/register/page.tsx",
        "app/login/page.tsx",
        "app/forgot-password/page.tsx",
        "app/reset-password/page.tsx",
        "app/confirm-email/page.tsx",
        "app/auth/confirm/route.ts",
        "app/api/check-email-confirmation/route.ts",
        "app/api/resend-confirmation/route.ts",
        "app/api/delete-user/route.ts",
        "lib/auth.ts",
        "lib/user-utils.ts",
        "lib/supabase.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "AnestEasy Auth API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/check-email-confirmation": {
            "get": {
              "summary": "Verifica se o email do usuário foi confirmado",
              "responses": {
                "200": {
                  "description": "Email confirmado"
                },
                "400": {
                  "description": "Parâmetros inválidos"
                },
                "401": {
                  "description": "Não autorizado"
                }
              }
            }
          },
          "/auth/confirm": {
            "post": {
              "summary": "Confirmação de email via link mágico Supabase",
              "responses": {
                "302": {
                  "description": "Redireciona para página de sucesso ou erro"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Subscription and Billing",
      "description": "Gestão de planos de assinatura, criação de sessão de checkout, portal de gerenciamento, atualização de planos, cancelamento e reembolso, com sincronização de status via webhooks Stripe.",
      "files": [
        "app/planos/page.tsx",
        "app/checkout/page.tsx",
        "app/checkout/success/page.tsx",
        "app/assinatura/page.tsx",
        "app/api/stripe/checkout/route.ts",
        "app/api/stripe/portal/route.ts",
        "app/api/stripe/subscription/route.ts",
        "app/api/stripe/subscription/cancel/route.ts",
        "app/api/stripe/subscription/change-plan/route.ts",
        "app/api/stripe/subscription/refund/route.ts",
        "app/api/stripe/sync-subscription/route.ts",
        "app/api/stripe/webhook/route.ts",
        "app/api/stripe/test-webhook/route.ts",
        "lib/stripe.ts",
        "lib/subscription.ts",
        "lib/subscription-access.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "AnestEasy Subscription API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/stripe/checkout": {
            "post": {
              "summary": "Cria sessão de checkout de assinatura na Stripe",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "plan_type": {
                          "type": "string",
                          "enum": ["monthly", "quarterly", "annual"]
                        }
                      },
                      "required": ["plan_type"]
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Sessão de checkout criada com sucesso"
                },
                "400": {
                  "description": "Dados inválidos"
                },
                "500": {
                  "description": "Erro interno ao criar sessão"
                }
              }
            }
          },
          "/api/stripe/subscription": {
            "get": {
              "summary": "Busca assinatura ativa do usuário autenticado",
              "responses": {
                "200": {
                  "description": "Assinatura encontrada"
                },
                "401": {
                  "description": "Não autorizado"
                },
                "404": {
                  "description": "Assinatura não encontrada"
                }
              }
            },
            "post": {
              "summary": "Registra nova assinatura após checkout Stripe",
              "requestBody": {
                "required": true,
                "content": {
                  "application/json": {
                    "schema": {
                      "type": "object",
                      "properties": {
                        "plan_type": {
                          "type": "string"
                        },
                        "stripe_subscription_id": {
                          "type": "string"
                        },
                        "stripe_customer_id": {
                          "type": "string"
                        }
                      },
                      "required": ["plan_type", "stripe_subscription_id"]
                    }
                  }
                }
              },
              "responses": {
                "200": {
                  "description": "Assinatura criada com sucesso"
                },
                "400": {
                  "description": "Dados inválidos ou assinatura já existente"
                },
                "500": {
                  "description": "Erro ao criar assinatura"
                }
              }
            }
          },
          "/api/stripe/subscription/cancel": {
            "post": {
              "summary": "Cancela assinatura ativa do usuário",
              "responses": {
                "200": {
                  "description": "Assinatura cancelada com sucesso"
                },
                "400": {
                  "description": "Requisição inválida"
                },
                "500": {
                  "description": "Erro ao cancelar assinatura"
                }
              }
            }
          },
          "/api/stripe/webhook": {
            "post": {
              "summary": "Recebe eventos de webhook da Stripe para atualizar status de assinatura",
              "responses": {
                "200": {
                  "description": "Webhook processado com sucesso"
                },
                "400": {
                  "description": "Assinatura inválida ou payload incorreto"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Procedures Management with OCR",
      "description": "CRUD de procedimentos anestésicos com dados de paciente, equipe, status, além de upload e recuperação de imagens e extração de dados via OCR.",
      "files": [
        "app/procedimentos/page.tsx",
        "app/procedimentos/novo/page.tsx",
        "app/admin/recover-images/page.tsx",
        "app/api/recover-images/route.ts",
        "app/api/fix-rls-procedures/route.ts",
        "lib/procedures.ts",
        "lib/image-recovery.ts",
        "lib/direct-storage-recovery.ts",
        "lib/database-recovery.ts",
        "lib/mime-utils.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "AnestEasy Procedures API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/recover-images": {
            "post": {
              "summary": "Recupera imagens de procedimentos a partir do storage ou banco",
              "responses": {
                "200": {
                  "description": "Processo de recuperação iniciado/completado"
                },
                "500": {
                  "description": "Erro durante a recuperação de imagens"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Financial Management and Reports",
      "description": "Controle de receitas e despesas, metas financeiras, gráficos analíticos e relatórios exportáveis em PDF/CSV.",
      "files": [
        "app/financeiro/page.tsx",
        "app/relatorios/page.tsx",
        "lib/goals.ts",
        "lib/reports.ts",
        "lib/anestesistas.ts",
        "lib/shifts.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "AnestEasy Finance and Reports API",
          "version": "1.0.0"
        },
        "paths": {}
      }
    },
    {
      "name": "Secretary Portal and Access Control",
      "description": "Gestão de secretárias pelo anestesiologista, convites por email, redefinição de senha de secretária e portal separado com permissões restritas.",
      "files": [
        "app/secretaria/layout.tsx",
        "app/secretaria/login/page.tsx",
        "app/secretaria/dashboard/page.tsx",
        "app/secretaria/configuracoes/page.tsx",
        "app/secretaria/procedimentos/[id]/page.tsx",
        "app/secretaria/anestesista/[id]/page.tsx",
        "app/secretaria/register/[token]/page.tsx",
        "app/api/secretaria/generate-invite/route.ts",
        "app/api/secretaria/validate-invite/route.ts",
        "app/api/secretaria/use-invite/route.ts",
        "app/api/secretaria/accept-link/route.ts",
        "app/api/secretaria/reject-link/route.ts",
        "app/api/reset-secretaria-password/route.ts",
        "app/api/send-secretaria-welcome/route.ts",
        "lib/secretarias.ts",
        "lib/feedback.ts",
        "lib/subscription-access.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "AnestEasy Secretary Management API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/secretaria/generate-invite": {
            "post": {
              "summary": "Gera convite de secretaria vinculado a um anestesiologista e envia email",
              "responses": {
                "200": {
                  "description": "Convite gerado com sucesso"
                },
                "400": {
                  "description": "Dados inválidos"
                }
              }
            }
          },
          "/api/secretaria/validate-invite": {
            "get": {
              "summary": "Valida token de convite de secretaria",
              "responses": {
                "200": {
                  "description": "Convite válido"
                },
                "400": {
                  "description": "Convite inválido ou expirado"
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "Email and SMTP Testing",
      "description": "Envio de emails transacionais via SMTP/Resend e rotas de teste para validar configuração de envio.",
      "files": [
        "app/test-smtp/page.tsx",
        "app/api/test-smtp/route.ts",
        "app/api/test-smtp-auth/route.ts",
        "app/api/test-smtp-direct/route.ts",
        "lib/utils.ts",
        "supabase/edge-functions/send-email/index.ts"
      ],
      "api_doc": {
        "openapi": "3.0.0",
        "info": {
          "title": "AnestEasy Email Test API",
          "version": "1.0.0"
        },
        "paths": {
          "/api/test-smtp": {
            "post": {
              "summary": "Teste de envio de email usando configuração SMTP padrão",
              "responses": {
                "200": {
                  "description": "Email enviado com sucesso"
                },
                "500": {
                  "description": "Falha ao enviar email"
                }
              }
            }
          }
        }
      }
    }
  ]
}

